# ── server/.env.example ──────────────────────────────────────────────
# Copy this file to server/.env and fill in real values.
# server/.env is git-ignored and must never be committed.

PORT=5000

# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/productpulse
# …or MongoDB Atlas (replace with your own connection string):
# MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/productpulse

# Use a long random string in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Allowed frontend origin for CORS (the CRA dev server)
CLIENT_URL=http://localhost:3000

# ProductPulse uses a seeded MongoDB collection as its data source, so there is
# no third-party API key here. When an app DOES need a keyed API, the key lives
# in this file ONLY (e.g. TMDB_API_KEY=) and is used from server/src/services/.
